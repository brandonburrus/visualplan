{
  "name": "vplan",
  "version": "0.1.0",
  "description": "Render an AI agent's plans as visual MDX pages instead of walls of text",
  "author": "Brandon Burrus <brandon@burrus.io>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/brandonburrus/visualplan.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/brandonburrus/visualplan#readme",
  "bugs": "https://github.com/brandonburrus/visualplan/issues",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "bin": {
    "vplan": "dist/index.js"
  },
  "files": [
    "dist",
    "runtime",
    "core"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "vendor": "node scripts/vendor.mjs",
    "prepack": "node scripts/vendor.mjs && tsup"
  },
  "dependencies": {
    "@mdx-js/mdx": "^3.1.1",
    "@mdx-js/react": "^3.1.1",
    "@mdx-js/rollup": "^3.1.1",
    "@tabler/icons-react": "^3.44.0",
    "beautiful-mermaid": "^1.1.3",
    "commander": "^15.0.0",
    "open": "^11.0.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "recharts": "^3.8.1",
    "rehype-expressive-code": "^0.43.1",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "remark-mdx": "^3.1.1",
    "remark-mdx-frontmatter": "^5.2.0",
    "remark-parse": "^11.0.0",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0",
    "vite": "^8.0.16",
    "vite-plugin-singlefile": "^2.3.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@visualplan/core": "workspace:*",
    "@visualplan/runtime": "workspace:*"
  }
}
