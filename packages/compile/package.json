{
  "name": "@visualplan/compile",
  "version": "0.1.0",
  "description": "Shared MDX compile pipeline (remark plugins, plan-block parser, Expressive Code options, safety gate) used by the vplan CLI and the /view page, so both render plans identically",
  "license": "MIT",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./file-icons": "./src/file-icons.ts",
    "./filetree-icons": "./src/remark-filetree-icons.ts",
    "./package.json": "./package.json"
  },
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@expressive-code/core": "0.43.1",
    "@visualplan/core": "workspace:*",
    "expressive-code-color-chips": "^0.1.4",
    "hast-util-from-html": "^2.0.3",
    "material-icon-theme": "^5.35.0",
    "rehype-expressive-code": "^0.43.1",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "remark-mdx": "^3.1.1",
    "remark-mdx-frontmatter": "^5.2.0",
    "remark-parse": "^11.0.0",
    "temml": "^0.13.3",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0"
  },
  "devDependencies": {
    "@types/hast": "^3.0.4"
  }
}
